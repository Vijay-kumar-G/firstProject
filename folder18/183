class Solution {
    public boolean check(int[] nums) {
        int count=0;
        if(nums.length<=1){
            return true;
        }
        for(int i=0;i<nums.length-1;i++){
            if(nums[i] > nums[i+1]){
                ++count;
                if(count >1) return false;
            }
        }
        if(nums[0] < nums[nums.length-1]) ++count;
        return count<=1;
    }
}//by vj
